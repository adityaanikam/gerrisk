# =============================================================================
# GeriRisk — Python Machine Learning Project .gitignore
# Following GitHub best practices for Python projects
# =============================================================================

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# Python Cache & Compiled Files
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# -----------------------------------------------------------------------------
# Jupyter Notebook Checkpoints
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Environment Variable Files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# IDE & Editor Folders
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS-Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
log/

# -----------------------------------------------------------------------------
# Build & Distribution Folders
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
share/python-wheels/
MANIFEST

# -----------------------------------------------------------------------------
# Pytest & Coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
nosetests.xml
test-results/

# -----------------------------------------------------------------------------
# Mypy & Type Checkers
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# -----------------------------------------------------------------------------
# Temporary Files & SQLite Databases
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# Machine Learning Artifacts
# -----------------------------------------------------------------------------
*.pkl
*.pickle
*.h5
*.hdf5
*.ckpt
*.pt
*.pth
*.joblib
models/
checkpoints/
runs/

# -----------------------------------------------------------------------------
# Data Files (large or sensitive)
# -----------------------------------------------------------------------------
data/raw/
data/processed/

# -----------------------------------------------------------------------------
# Package Manager
# -----------------------------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Distribution / Packaging
# -----------------------------------------------------------------------------
*.so
*.pyd
/lib/
/lib64/
parts/
sdist/
var/
