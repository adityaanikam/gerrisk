**/.env
**/.env.*
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Editor / OS
.DS_Store
Thumbs.db
**/*.swp
**/*.swo
.idea
.vscode

# Git
.git
.gitignore

# Docker files themselves (no need to copy)
**/Dockerfile*
docker-compose*.yml

# Docs / extras not needed in image
GeriRiskCSVs
*.md

# Misc
*.log
coverage
.nyc_output
